# MySQL/MariaDB (127.0.0.1:3306)
DATABASE_URL=mysql://ctsapp:YOUR_PASSWORD@127.0.0.1:3306/cts_app
PORT=8081
PUBLIC_HOST=64.119.30.250

# SSL — өөрийн домэйнгүй: 64-119-30-250.sslip.io (DNS тохируулахгүй)
# npm run ssl:letsencrypt → https://64-119-30-250.sslip.io:8081
SSL_DOMAIN=64-119-30-250.sslip.io
LETSENCRYPT_EMAIL=admin@example.com
SSL_DNS_MANUAL=0

# Эсвэл HTTP (анхааруулгагүй): SSL_DISABLED=1 + http://64.119.30.250:8081
